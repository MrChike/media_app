# Note:
# Containers communicate using Docker Compose service names, ensuring reliable 
# networking without the need to manage specific IP addresses.

# OMDb API Configuration
OMDb_MOVIES_API_KEY="YOUR API KEY -> https://www.omdbapi.com/apikey.aspx"

# PostgreSQL Configuration
POSTGRES_USER="root"
POSTGRES_PASSWORD="root"
POSTGRES_HOST="postgres"      # Docker Compose service name
POSTGRES_PORT="5432"
POSTGRES_NAME="root"

# MongoDB Configuration
MONGODB_USER="root"
MONGODB_PASSWORD="root"
MONGODB_HOST="mongo"          # Docker Compose service name
MONGODB_PORT="27017"
MONGODB_NAME="root"

# Redis Configuration
REDIS_PASSWORD="root"
REDIS_HOST="redis"            # Docker Compose service name
REDIS_PORT="6379"
